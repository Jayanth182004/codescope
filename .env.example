# =============================================================================
# CodeScope AI — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=codescope_user
POSTGRES_PASSWORD=codescope_secure_pass_387
POSTGRES_DB=codescope_dev

# Full DSN used by the FastAPI backend (constructed from above in docker-compose)
# For local development without Docker, set this directly:
# DATABASE_URL=postgresql://codescope_user:codescope_secure_pass_387@localhost:5432/codescope_dev
DATABASE_URL=postgresql://codescope_user:codescope_secure_pass_387@db:5432/codescope_dev

# ── Neo4j Knowledge Graph ─────────────────────────────────────────────────────
# Bolt URI — use bolt:// for local, neo4j+s:// for AuraDB / TLS-enabled clusters
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=codescope_neo4j_pass
NEO4J_DATABASE=neo4j

# Graph performance tuning
GRAPH_BATCH_SIZE=500
GRAPH_MAX_DEPTH=8
GRAPH_MAX_SUBGRAPH_NODES=5000

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=codescope_super_secret_signing_key_387d89f2e3c09b7

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads
MAX_ZIP_SIZE_BYTES=104857600          # 100 MB
MAX_EXTRACTED_SIZE_BYTES=524288000    # 500 MB
MAX_ZIP_FILES=20000
MAX_ANALYSIS_FILES=50000
MAX_ANALYZED_FILE_SIZE_BYTES=5242880  # 5 MB

# ── CORS (comma-separated origins) ───────────────────────────────────────────
# BACKEND_CORS_ORIGINS=http://localhost:5173,https://your-domain.com
